# API origin (no trailing slash, no /api suffix)
# Leave empty in dev to use Vite proxy → http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000

# Dev proxy target (optional, used by vite.config.js server.proxy)
# VITE_API_PROXY=http://localhost:5000

# Admin month pickers start at June of this year (Jan–May are not selectable)
# VITE_FIRST_SELECTABLE_YEAR=2025

# Phrase required for destructive backup restore
# VITE_RESTORE_CONFIRM_PHRASE=RESTORE_NOW
