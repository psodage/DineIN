{
  "name": "dinein",
  "version": "1.0.0",
  "private": true,
  "description": "DineIN — Mess Management System Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "dev:backend": "turbo run dev --filter=@dinein/backend",
    "dev:admin": "turbo run dev --filter=@dinein/admin-web",
    "dev:member-web": "turbo run dev --filter=@dinein/member-web",
    "dev:mobile": "turbo run dev --filter=@dinein/member-mobile",
    "db:generate": "pnpm --filter @dinein/database run generate",
    "db:migrate": "pnpm --filter @dinein/database run migrate",
    "db:seed": "pnpm --filter @dinein/database run seed",
    "db:studio": "pnpm --filter @dinein/database run studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.0"
  },
  "packageManager": "pnpm@10.12.1"
}
